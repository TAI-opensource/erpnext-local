{
  "buildCommand": "yarn build:local",
  "outputDirectory": "dist-local",
  "framework": "vite",
  "installCommand": "yarn install",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/wasm/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\..*|wasm).*)",
      "destination": "/index.html"
    }
  ]
}
